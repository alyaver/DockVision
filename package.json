{
  "name": "dockvision",
  "private": true,
  "workspaces": ["client", "server"],
  "scripts": {
    "dev": "concurrently -k -n client,server \"npm run dev -w client\" \"npm run dev -w server\"",
    "dev:client": "npm run dev -w client",
    "dev:server": "npm run dev -w server",
    "install:all": "npm install"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  }
}
